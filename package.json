{
  "name": "warehouse-microservice",
  "version": "1.0.0",
  "description": "Centralized warehouse and stock management - tracks stock across all warehouses with real-time updates via RabbitMQ",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json --incremental false",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/typeorm-data-source.ts",
    "migration:show": "npm run typeorm -- migration:show",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js -d dist/src/database/typeorm-data-source.js migration:run",
    "migration:show:prod": "node ./node_modules/typeorm/cli.js -d dist/src/database/typeorm-data-source.js migration:show",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "check:hosted-auth": "node scripts/check-hosted-auth-contract.js",
    "verify:stock-authority-live": "node scripts/verify-stock-authority-live.js",
    "verify:goal24-warehouse-no-mutation-ack": "node scripts/verify-goal24-warehouse-no-mutation-ack.js",
    "verify:goal24-selected-reservation-lookup": "node scripts/verify-goal24-selected-reservation-lookup.js",
    "verify:bundle-component-reservation": "node scripts/verify-bundle-component-reservation-contract.js",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "verify:business-health-stock-authority-contract": "node scripts/verify-business-health-stock-authority-contract.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/axios": "^3.0.1",
    "@nestjs/microservices": "^10.0.0",
    "typeorm": "^0.3.17",
    "pg": "^8.11.3",
    "amqplib": "^0.10.3",
    "amqp-connection-manager": "^4.1.14",
    "axios": "^1.6.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0",
    "@nestjs/jwt": "^10.2.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/amqplib": "^0.10.4",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "testEnvironment": "node"
  }
}
